# PaymentFlow AI currently runs as a self-contained demonstration with mock data.
# No environment variables are required for the Vercel demo deployment.
#
# Future production integrations should be added here using names only, never secrets:
# DATABASE_URL=
# AUTH_SECRET=
# AI_PROVIDER_API_KEY=
# EXCHANGE_RATE_PROVIDER_API_KEY=
# PAYMENT_PROVIDER_API_KEY=

# Public canonical URL used by generated sitemap metadata (optional)
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
